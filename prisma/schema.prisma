generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  customer
  admin
  staff
  delivery
}

enum OrderStatus {
  pending_verification
  verified
  packing
  out_for_delivery
  delivered
}

enum EmailType {
  registration_welcome
  order_confirmation
  order_out_for_delivery
  order_delivered
}

model User {
  id           String   @id @default(cuid())
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id])
  username     String
  email        String
  passwordHash String
  name         String
  role         Role     @default(customer)
  emailVerifiedAt    DateTime?
  emailVerifyToken   String?
  emailVerifyExpires DateTime?
  avatarUrl    String?
  onBreak      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders         Order[]
  emailLogs      EmailLog[]
  assignedOrders Order[]    @relation("OrderRider")

  @@unique([storeId, username])
  @@unique([storeId, email])
  @@index([storeId])
  @@map("users")
}

model Product {
  id            String      @id @default(cuid())
  storeId       String
  store         Store       @relation(fields: [storeId], references: [id])
  name          String
  brand         String
  size          String
  price         Int
  category      String
  description   String
  comboEligible Boolean     @default(false)
  stock         Int         @default(0)
  imageUrl      String?
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  orderItems OrderItem[]

  @@index([storeId])
  @@map("products")
}

model Order {
  id             String      @id @default(cuid())
  orderNumber    Int         @unique @default(autoincrement())
  displayId      String      @unique
  storeId        String
  store          Store       @relation(fields: [storeId], references: [id])
  userId         String
  user           User        @relation(fields: [userId], references: [id])
  status         OrderStatus @default(pending_verification)
  phone          String
  address        String
  subtotal       Int
  comboDiscount  Int
  total          Int
  distanceKm     Float?
  eta            String?
  packingSlot    String?
  priority       String      @default("Standard")
  screenshotName String?
  paymentProofUrl String?
  paymentMethod  String      @default("upi")
  riderId        String?
  rider          User?       @relation("OrderRider", fields: [riderId], references: [id])
  acceptedAt     DateTime?
  verifiedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  items      OrderItem[]
  emailLogs  EmailLog[]

  @@index([storeId])
  @@index([userId])
  @@index([status])
  @@index([riderId])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Int

  @@map("order_items")
}

model Store {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  codePrefix     String   @unique
  openingTime    String   @default("09:00")
  closingTime    String   @default("20:00")
  hourlyCapacity Int      @default(40)
  upiId          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users      User[]
  products   Product[]
  orders     Order[]
  emailLogs  EmailLog[]
  categories Category[]

  @@map("stores")
}

model Category {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  name      String
  createdAt DateTime @default(now())

  @@unique([storeId, name])
  @@index([storeId])
  @@map("categories")
}

model EmailLog {
  id        String    @id @default(cuid())
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id])
  userId    String?
  user      User?     @relation(fields: [userId], references: [id])
  orderId   String?
  order     Order?    @relation(fields: [orderId], references: [id])
  type      EmailType
  toEmail   String
  status    String
  error     String?
  createdAt DateTime  @default(now())

  @@index([storeId])
  @@map("email_logs")
}
