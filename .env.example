# Postgres connection string (e.g. Supabase connection pooler URL, or local Postgres.app)
DATABASE_URL="postgresql://user:password@localhost:5432/bhagwandas_traders?schema=public"

# Direct Postgres connection for Prisma migrations
DIRECT_URL="postgresql://user:password@localhost:5432/bhagwandas_traders?schema=public"

# SMTP settings for transactional email
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp-user"
SMTP_PASSWORD="smtp-password"
SMTP_FROM_ADDRESS="no-reply@example.com"

# Absolute origin used to build links embedded in emails (no trailing slash)
APP_BASE_URL="http://localhost:3000"
